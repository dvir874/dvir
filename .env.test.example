# ============================================================
# STAGING / E2E TEST ENVIRONMENT
# ============================================================
# Copy this file to .env.test (gitignored) and fill in a
# SEPARATE Supabase project — NEVER use production credentials here.
#
# Setup steps:
# 1. Go to https://app.supabase.com → New project (free tier is fine)
# 2. In SQL Editor, run: supabase/schema.sql
# 3. Copy the project URL and service role key below
# 4. Run E2E tests with: dotenv -e .env.test -- npm run dev
# ============================================================

# Must NOT match production URL (vrxeqhtdwgnwsgusvywx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=staging-service-role-key

ADMIN_TOKEN=staging-admin-token-set-this
ADMIN_PASSWORD=staging-admin-password

NEXT_PUBLIC_BASE_URL=http://localhost:3001
CRON_SECRET=staging-cron-secret

# Sentry — leave disabled in staging to avoid noise in production Sentry project
ENABLE_SENTRY=false
ENABLE_STRUCTURED_LOGS=false
ENABLE_HEALTH_ENDPOINT=true

# After running: npm run seed:staging
# RSVP test: http://localhost:3001/rsvp/staging-rsvp-01
# Couple dashboard: http://localhost:3001/couple/staging-test-token-2026
