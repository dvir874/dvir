# ============================================================
# REQUIRED — copy this file to .env.local and fill in values
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# SPRINT 1 — Production Visibility
# ============================================================

# Feature flags — set to "true" to enable each component.
# Changing requires a Vercel redeploy (~2 min).
ENABLE_SENTRY=false               # set to true in production after adding DSN
ENABLE_STRUCTURED_LOGS=false      # set to true in production
ENABLE_HEALTH_ENDPOINT=true       # safe to enable everywhere

# Sentry — create a project at sentry.io (free tier)
NEXT_PUBLIC_SENTRY_DSN=           # https://xxx@oXXX.ingest.sentry.io/XXX
SENTRY_DSN=                       # same value as above (server-side)
SENTRY_ORG=                       # your Sentry org slug
SENTRY_PROJECT=                   # your Sentry project slug
SENTRY_AUTH_TOKEN=                # for source map uploads in CI only

# Optional: app version shown in /api/health response
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================================
# ⚠️  CRITICAL — set this even in local dev!
# Without ADMIN_TOKEN, DELETE/PUT on admin API routes are BLOCKED.
# This prevents accidental data loss against the production database.
# Use any random string: openssl rand -hex 32
ADMIN_TOKEN=dev-local-token-change-me
ADMIN_PASSWORD=your-admin-password

# Public base URL (for RSVP links sent to guests)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cron job secret (required in production)
CRON_SECRET=your-cron-secret

# ============================================================
# STAGING — for E2E tests, use a SEPARATE Supabase project!
# ============================================================
# Create a free Supabase project at https://app.supabase.com
# Run supabase/schema.sql against it, then copy values to .env.test
# NEVER point E2E tests at the production SUPABASE_URL above.
# ============================================================

# Google Sheets sync (optional — disabled if not set)
GOOGLE_SHEETS_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
